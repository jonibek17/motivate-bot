# Telegram Bot Token (obtained from Telegram's @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (obtained from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL / Neon Connection String
# If left empty, the bot will use a local JSON file database for mock testing.
DATABASE_URL=postgres://user:password@hostname:5432/dbname?sslmode=require

# Port for the Admin Dashboard and Backend Server
PORT=5000
